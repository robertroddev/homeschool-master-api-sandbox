<!DOCTYPE html>
<html>
  <body style="margin: 0; padding: 0; background-color: #fbf7ee; font-family: Arial, Helvetica, sans-serif; color: #494242;">
    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="padding: 32px 16px;">
      <tr>
        <td align="center">
          <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="max-width: 480px; background: #ffffff; border-radius: 16px; overflow: hidden;">
            <tr>
              <td style="background: linear-gradient(to bottom, #ecbb77, #fff9d2); padding: 32px; text-align: center;">
                <h1 style="margin: 0; font-size: 22px; color: #231f20; text-transform: uppercase; letter-spacing: 0.5px;">Reset Your Password</h1>
              </td>
            </tr>
            <tr>
              <td style="padding: 32px;">
                <p style="margin: 0 0 16px; font-size: 16px; line-height: 1.6;">Hi <%= @teacher.first_name %>,</p>
                <p style="margin: 0 0 24px; font-size: 16px; line-height: 1.6;">
                  We received a request to reset your Homeschool Master password. Click the button below to choose a new one. This link expires in 1 hour.
                </p>
                <table role="presentation" cellpadding="0" cellspacing="0" style="margin: 0 auto 24px;">
                  <tr>
                    <td align="center" style="border-radius: 24px; background: #d97b0a;">
                      <a href="<%= @reset_url %>" style="display: inline-block; padding: 14px 32px; font-size: 16px; font-weight: 700; color: #ffffff; text-decoration: none; border-radius: 24px;">Reset Password</a>
                    </td>
                  </tr>
                </table>
                <p style="margin: 0 0 8px; font-size: 13px; line-height: 1.6; color: #888;">
                  If the button doesn't work, copy and paste this link into your browser:
                </p>
                <p style="margin: 0 0 24px; font-size: 13px; line-height: 1.6; word-break: break-all;">
                  <a href="<%= @reset_url %>" style="color: #d97b0a;"><%= @reset_url %></a>
                </p>
                <p style="margin: 0; font-size: 13px; line-height: 1.6; color: #888;">
                  If you didn't request this, you can safely ignore this email: your password won't change.
                </p>
              </td>
            </tr>
          </table>
        </td>
      </tr>
    </table>
  </body>
</html>
